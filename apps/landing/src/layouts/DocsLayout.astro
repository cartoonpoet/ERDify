---
interface Props {
  title?: string;
  description?: string;
  activePage?: 'overview' | 'mcp' | 'api';
}
const {
  title = 'Developer Center — ERDify',
  description = 'ERDify MCP 연동 및 REST API 레퍼런스',
  activePage = 'overview',
} = Astro.props;

const APP_URL = 'https://app.erdify.com';

const nav = [
  {
    group: '시작하기',
    items: [
      { label: 'Developer Center', href: '/docs', key: 'overview' },
    ],
  },
  {
    group: 'MCP 연동',
    items: [
      { label: 'MCP 가이드', href: '/docs/mcp-integration', key: 'mcp' },
    ],
  },
  {
    group: 'REST API',
    items: [
      { label: 'API 레퍼런스', href: '/docs/api-reference', key: 'api' },
    ],
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --primary: #0064E0;
        --primary-hover: #0143B5;
        --text: #1C2B33;
        --text-sub: #5D6C7B;
        --border: #DEE3E9;
        --surface: #F1F4F7;
        --white: #FFFFFF;
        --font: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, sans-serif;
        --sidebar-w: 256px;
        --header-h: 60px;
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--text);
        background: var(--white);
        -webkit-font-smoothing: antialiased;
      }
      img { max-width: 100%; display: block; }
      a { color: inherit; text-decoration: none; }
      button { font-family: var(--font); cursor: pointer; }
    </style>
  </head>
  <body>
    <!-- Header -->
    <header class="dh">
      <div class="dh-inner">
        <!-- Left: logo + breadcrumb -->
        <div class="dh-left">
          <a href="/" class="dh-logo">
            <img src="/logo-white.svg" alt="ERDify" class="dh-logo-img" />
          </a>
          <span class="dh-sep">/</span>
          <a href="/docs" class="dh-product">Developer Center</a>
        </div>

        <!-- Center: nav -->
        <nav class="dh-nav">
          <a href="/docs/mcp-integration" class:list={['dh-link', activePage === 'mcp' ? 'dh-link--active' : '']}>MCP 연동</a>
          <a href="/docs/api-reference" class:list={['dh-link', activePage === 'api' ? 'dh-link--active' : '']}>REST API</a>
        </nav>

        <!-- Right: CTA -->
        <div class="dh-right">
          <a href="/" class="dh-back">← 랜딩으로</a>
          <a href={`${APP_URL}/settings/api`} class="dh-cta">API 키 발급</a>
        </div>
      </div>
    </header>

    <!-- Shell -->
    <div class="ds">
      <!-- Sidebar -->
      <aside class="ds-sidebar">
        {nav.map((section) => (
          <div class="sb-group">
            <div class="sb-group-label">{section.group}</div>
            {section.items.map((item) => (
              <a
                href={item.href}
                class:list={['sb-link', item.key === activePage ? 'sb-link--active' : '']}
              >
                {item.label}
              </a>
            ))}
          </div>
        ))}

        <div class="sb-divider" />

        <a href={`${APP_URL}/settings/api`} class="sb-api-btn">
          🔑 API 키 발급하기 →
        </a>
      </aside>

      <!-- Main -->
      <main class="ds-main">
        <div class="ds-content">
          <slot />
        </div>
      </main>
    </div>

    <style>
      /* ── Header ── */
      .dh {
        position: sticky;
        top: 0;
        z-index: 100;
        height: var(--header-h);
        background: #0f1923;
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .dh-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        height: 100%;
        display: flex;
        align-items: center;
        gap: 0;
      }

      /* Logo + breadcrumb */
      .dh-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
      }
      .dh-logo { display: flex; align-items: center; }
      .dh-logo-img { width: 138px; height: 36px; display: block; }
      .dh-sep {
        color: rgba(255,255,255,0.2);
        font-size: 18px;
        font-weight: 300;
        line-height: 1;
        margin: 0 2px;
      }
      .dh-product {
        font-size: 14px;
        font-weight: 600;
        color: rgba(255,255,255,0.55);
        transition: color 0.15s;
        white-space: nowrap;
      }
      .dh-product:hover { color: #fff; }

      /* Nav */
      .dh-nav {
        display: flex;
        gap: 4px;
        margin-left: 40px;
        flex: 1;
      }
      .dh-link {
        font-size: 14px;
        font-weight: 500;
        color: rgba(255,255,255,0.55);
        padding: 6px 12px;
        border-radius: 6px;
        transition: color 0.15s, background 0.15s;
        white-space: nowrap;
      }
      .dh-link:hover { color: #fff; background: rgba(255,255,255,0.07); }
      .dh-link--active { color: #fff; font-weight: 600; }

      /* Right */
      .dh-right {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-shrink: 0;
      }
      .dh-back {
        font-size: 13px;
        font-weight: 500;
        color: rgba(255,255,255,0.4);
        padding: 6px 10px;
        border-radius: 6px;
        transition: color 0.15s, background 0.15s;
      }
      .dh-back:hover { color: rgba(255,255,255,0.8); background: rgba(255,255,255,0.06); }
      .dh-cta {
        font-size: 13px;
        font-weight: 600;
        color: #fff;
        background: var(--primary);
        padding: 7px 16px;
        border-radius: 8px;
        transition: background 0.15s;
        white-space: nowrap;
      }
      .dh-cta:hover { background: var(--primary-hover); }

      /* ── Shell ── */
      .ds {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: var(--sidebar-w) 1fr;
        min-height: calc(100vh - var(--header-h));
        gap: 0;
      }

      /* ── Sidebar ── */
      .ds-sidebar {
        position: sticky;
        top: var(--header-h);
        height: calc(100vh - var(--header-h));
        overflow-y: auto;
        padding: 32px 20px 32px 0;
        border-right: 1px solid var(--border);
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
      }
      .sb-group { margin-bottom: 32px; }
      .sb-group-label {
        font-size: 10.5px;
        font-weight: 700;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        color: var(--text-sub);
        padding: 0 12px;
        margin-bottom: 4px;
      }
      .sb-link {
        display: flex;
        align-items: center;
        font-size: 14px;
        font-weight: 450;
        color: var(--text-sub);
        padding: 8px 12px;
        border-radius: 8px;
        transition: color 0.12s, background 0.12s;
        line-height: 1.4;
      }
      .sb-link:hover { color: var(--text); background: var(--surface); }
      .sb-link--active {
        color: var(--primary);
        background: #EEF4FF;
        font-weight: 600;
        position: relative;
      }
      .sb-link--active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 6px;
        bottom: 6px;
        width: 2px;
        background: var(--primary);
        border-radius: 1px;
      }
      .sb-divider { border-top: 1px solid var(--border); margin: 8px 12px 20px; }
      .sb-api-btn {
        display: block;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--primary);
        padding: 9px 12px;
        border-radius: 8px;
        border: 1px solid rgba(0,100,224,0.25);
        background: #EEF4FF;
        transition: background 0.15s;
        text-align: center;
      }
      .sb-api-btn:hover { background: #dce8fc; }

      /* ── Main ── */
      .ds-main { padding: 52px 0 96px 60px; }
      .ds-content { max-width: 760px; }

      /* ── Responsive ── */
      @media (max-width: 900px) {
        .ds { grid-template-columns: 1fr; padding: 0 20px; }
        .ds-sidebar { display: none; }
        .ds-main { padding: 32px 0 64px 0; }
        .dh-nav { display: none; }
        .dh-back { display: none; }
      }
      @media (max-width: 600px) {
        .dh-sep, .dh-product { display: none; }
      }
    </style>
  </body>
</html>
