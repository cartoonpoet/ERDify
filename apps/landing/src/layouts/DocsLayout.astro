---
interface Props {
  title?: string;
  description?: string;
  activePage?: 'overview' | 'mcp' | 'api';
}
const {
  title = 'Developer Center — ERDify',
  description = 'ERDify MCP 연동 및 REST API 레퍼런스',
  activePage = 'overview',
} = Astro.props;

const APP_URL = 'https://app.erdify.com';

const nav = [
  {
    group: '시작하기',
    items: [
      { label: 'Developer Center', href: '/docs', key: 'overview' },
    ],
  },
  {
    group: 'MCP 연동',
    items: [
      { label: 'MCP 가이드', href: '/docs/mcp-integration', key: 'mcp' },
    ],
  },
  {
    group: 'REST API',
    items: [
      { label: 'API 레퍼런스', href: '/docs/api-reference', key: 'api' },
    ],
  },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --primary: #0064E0;
        --primary-hover: #0143B5;
        --text: #1C2B33;
        --text-sub: #5D6C7B;
        --border: #DEE3E9;
        --surface: #F1F4F7;
        --white: #FFFFFF;
        --font: 'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, sans-serif;
        --sidebar-w: 256px;
        --header-h: 60px;
      }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        color: var(--text);
        background: var(--white);
        -webkit-font-smoothing: antialiased;
      }
      img { max-width: 100%; display: block; }
      a { color: inherit; text-decoration: none; }
      button { font-family: var(--font); cursor: pointer; }
    </style>
  </head>
  <body>

    <!-- ── Header (랜딩과 동일한 스타일) ── -->
    <header class="dh">
      <div class="dh-inner">
        <a href="/" class="dh-logo">
          <img src="/logo.svg" alt="ERDify" class="dh-logo-img" />
        </a>

        <nav class="dh-nav">
          <a href="/docs/mcp-integration"
            class:list={['dh-link', activePage === 'mcp' ? 'dh-link--active' : '']}>MCP 연동</a>
          <a href="/docs/api-reference"
            class:list={['dh-link', activePage === 'api' ? 'dh-link--active' : '']}>REST API</a>
        </nav>

        <div class="dh-cta-group">
          <a href="/" class="dh-ghost">← 사이트로</a>
          <a href={`${APP_URL}/settings/api`} class="dh-btn">API 키 발급</a>
        </div>
      </div>
    </header>

    <!-- ── Body ── -->
    <div class="ds-shell">

      <!-- Sidebar -->
      <aside class="ds-sidebar">
        {nav.map((section) => (
          <div class="sb-section">
            <p class="sb-section-title">{section.group}</p>
            {section.items.map((item) => (
              <a
                href={item.href}
                class:list={['sb-item', item.key === activePage ? 'sb-item--active' : '']}
              >
                {item.label}
              </a>
            ))}
          </div>
        ))}

        <div class="sb-sep" />

        <a href={`${APP_URL}/settings/api`} class="sb-key-btn">
          🔑 API 키 발급하기 →
        </a>
      </aside>

      <!-- Main content -->
      <main class="ds-main">
        <div class="ds-content">
          <slot />
        </div>
      </main>
    </div>

    <style>
      /* ── Header ── */
      .dh {
        position: sticky;
        top: 0;
        z-index: 100;
        height: var(--header-h);
        background: rgba(255,255,255,0.85);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .dh-inner {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        height: 100%;
        display: flex;
        align-items: center;
        gap: 32px;
      }
      .dh-logo { display: flex; align-items: center; flex-shrink: 0; }
      .dh-logo-img { width: 138px; height: 36px; display: block; }

      .dh-nav { display: flex; gap: 28px; flex: 1; }
      .dh-link {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-sub);
        transition: color 0.15s;
      }
      .dh-link:hover { color: var(--text); }
      .dh-link--active { color: var(--primary); font-weight: 600; }

      .dh-cta-group { display: flex; gap: 10px; align-items: center; }
      .dh-ghost {
        font-size: 14px;
        font-weight: 500;
        color: var(--text-sub);
        padding: 9px 14px;
        border-radius: 8px;
        transition: background 0.15s;
      }
      .dh-ghost:hover { background: var(--surface); color: var(--text); }
      .dh-btn {
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        background: var(--primary);
        padding: 9px 18px;
        border-radius: 8px;
        transition: background 0.15s;
        white-space: nowrap;
      }
      .dh-btn:hover { background: var(--primary-hover); }

      /* ── Shell ── */
      .ds-shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 24px;
        display: grid;
        grid-template-columns: var(--sidebar-w) 1fr;
        min-height: calc(100vh - var(--header-h));
      }

      /* ── Sidebar ── */
      .ds-sidebar {
        position: sticky;
        top: var(--header-h);
        height: calc(100vh - var(--header-h));
        overflow-y: auto;
        padding: 32px 16px 40px 0;
        border-right: 1px solid var(--border);
        scrollbar-width: thin;
        scrollbar-color: var(--border) transparent;
      }
      .sb-section { margin-bottom: 28px; }
      .sb-section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--text-sub);
        padding: 0 12px;
        margin-bottom: 4px;
      }
      .sb-item {
        display: flex;
        align-items: center;
        font-size: 14px;
        font-weight: 450;
        color: var(--text-sub);
        padding: 8px 12px;
        border-radius: 8px;
        transition: color 0.12s, background 0.12s;
        position: relative;
      }
      .sb-item:hover { color: var(--text); background: var(--surface); }
      .sb-item--active {
        color: var(--primary);
        background: #EEF4FF;
        font-weight: 600;
      }
      .sb-item--active::before {
        content: '';
        position: absolute;
        left: 0;
        top: 8px;
        bottom: 8px;
        width: 2px;
        background: var(--primary);
        border-radius: 2px;
      }
      .sb-sep { border-top: 1px solid var(--border); margin: 8px 12px 20px; }
      .sb-key-btn {
        display: block;
        font-size: 12.5px;
        font-weight: 600;
        color: var(--primary);
        padding: 9px 12px;
        border-radius: 8px;
        border: 1px solid rgba(0,100,224,0.2);
        background: #EEF4FF;
        text-align: center;
        transition: background 0.15s;
      }
      .sb-key-btn:hover { background: #dce8fc; }

      /* ── Main ── */
      .ds-main { padding: 52px 0 96px 60px; }
      .ds-content { max-width: 760px; }

      /* ── Responsive ── */
      @media (max-width: 900px) {
        .ds-shell { grid-template-columns: 1fr; padding: 0 20px; }
        .ds-sidebar { display: none; }
        .ds-main { padding: 32px 0 64px 0; }
        .dh-nav { display: none; }
        .dh-ghost { display: none; }
      }
    </style>
  </body>
</html>
