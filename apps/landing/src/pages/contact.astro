---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
const APP_URL = 'http://erdify-app.kro.kr';

const faqs = [
  {
    q: '무료로 사용할 수 있나요?',
    a: '네, 현재 베타 기간 동안 모든 기능을 무료로 이용하실 수 있습니다. 정식 출시 후 요금제가 도입될 예정이며, 사전에 공지해 드립니다.',
  },
  {
    q: 'MCP 연동은 어떻게 설정하나요?',
    a: '개발자 센터의 MCP 연동 가이드를 참고하세요. Cursor, Claude Desktop, Gemini, Codex 등 주요 AI 도구와 연동할 수 있습니다.',
  },
  {
    q: '팀으로 함께 사용할 수 있나요?',
    a: '네, 실시간 협업을 지원합니다. 조직을 생성하고 팀원을 초대하면 동일한 ERD를 동시에 편집할 수 있습니다.',
  },
  {
    q: 'MySQL 이외의 데이터베이스도 지원하나요?',
    a: 'MySQL, PostgreSQL, MariaDB DDL 가져오기/내보내기를 지원합니다. 추가 DB 지원은 순차적으로 확대할 예정입니다.',
  },
  {
    q: '데이터는 안전하게 보관되나요?',
    a: '모든 데이터는 암호화되어 저장되며, 외부에 공유되지 않습니다. 상세한 내용은 개인정보처리방침을 참고해 주세요.',
  },
  {
    q: 'ERD를 이미지로 내보낼 수 있나요?',
    a: 'PNG 이미지 내보내기와 DDL SQL 내보내기를 지원합니다. ORM 코드(TypeORM, Prisma, SQLAlchemy) 생성도 가능합니다.',
  },
];
---

<Layout title="문의하기 — ERDify" description="ERDify 팀에 문의하세요. 이메일로 빠르게 답변해 드립니다.">
  <SiteHeader />

  <!-- Hero -->
  <section class="contact-hero">
    <div class="container">
      <div class="badge">고객지원</div>
      <h1>문의하기</h1>
      <p>궁금한 점이 있으시면 이메일로 문의해 주세요.<br/>빠르게 답변해 드리겠습니다.</p>

      <div class="contact-card">
        <div class="contact-icon">✉</div>
        <div class="contact-label">이메일로 문의하기</div>
        <a href="mailto:support@erdify.com" class="contact-email-btn">
          support@erdify.com
        </a>
        <p class="contact-sub">보통 1–2 영업일 내 답변해 드립니다.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section">
    <div class="container">
      <h2 class="faq-title">자주 묻는 질문</h2>
      <div class="faq-list">
        {faqs.map((item, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-q">
              <span class="faq-q-icon">Q.</span>
              {item.q}
              <span class="faq-chevron">›</span>
            </summary>
            <div class="faq-a">{item.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo">
          <img src="/logo.svg" alt="ERDify" class="logo-image" style="filter: brightness(0) invert(1);" />
        </a>
        <p class="footer-tagline">AI와 함께하는<br/>실시간 협업 ERD 도구</p>
        <a href="mailto:support@erdify.com" class="footer-email">support@erdify.com</a>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">제품</span>
          <a href="/#features">기능</a>
          <a href="/#integrations">AI 연동</a>
          <a href="/#pricing">가격</a>
          <a href={APP_URL}>앱 열기</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">지원</span>
          <a href="/contact">문의하기</a>
          <a href="mailto:support@erdify.com">이메일 문의</a>
          <a href="/docs/">개발자 센터</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">법적 고지</span>
          <a href="/terms">이용약관</a>
          <a href="/privacy">개인정보처리방침</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <span>© 2026 ERDify. All rights reserved.</span>
        <div class="footer-bottom-links">
          <a href="/terms">이용약관</a>
          <a href="/privacy">개인정보처리방침</a>
          <a href="/contact">문의</a>
        </div>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .container { max-width: 760px; margin: 0 auto; padding: 0 24px; }

  .badge {
    display: inline-block;
    background: #EEF4FF;
    color: var(--primary);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 14px;
    border-radius: 99px;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  /* ── Hero ── */
  .contact-hero {
    padding: 80px 0 64px;
    text-align: center;
    background: linear-gradient(180deg, #f8faff 0%, #fff 100%);
    border-bottom: 1px solid #f1f4f8;
  }
  .contact-hero h1 {
    font-size: 42px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    color: #111827;
  }
  .contact-hero > .container > p {
    font-size: 17px;
    color: #6b7280;
    line-height: 1.7;
    margin-bottom: 48px;
  }

  .contact-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 48px 40px 40px;
    box-shadow: 0 4px 24px rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    max-width: 460px;
    margin: 0 auto;
  }
  .contact-icon {
    width: 56px; height: 56px;
    background: #EEF4FF;
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    margin-bottom: 8px;
    color: var(--primary);
  }
  .contact-label { font-size: 13px; font-weight: 600; color: #6b7280; margin-bottom: 4px; }
  .contact-email-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--primary);
    color: #fff;
    font-size: 15px;
    font-weight: 700;
    padding: 14px 32px;
    border-radius: 12px;
    text-decoration: none;
    margin: 8px 0;
    transition: background .15s, transform .12s;
    font-family: monospace;
    letter-spacing: -.01em;
  }
  .contact-email-btn:hover { background: #0052C2; transform: translateY(-1px); }
  .contact-sub { font-size: 12px; color: #9ca3af; margin-top: 4px; }

  /* ── FAQ ── */
  .faq-section { padding: 80px 0 100px; }
  .faq-title {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 40px;
    text-align: center;
    color: #111827;
  }
  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item {
    border-bottom: 1px solid #f1f4f7;
  }
  .faq-item:first-child { border-top: 1px solid #f1f4f7; }
  .faq-q {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 4px;
    font-size: 15px;
    font-weight: 600;
    color: #111827;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q-icon { color: var(--primary); font-size: 13px; font-weight: 800; flex-shrink: 0; }
  .faq-chevron { margin-left: auto; font-size: 18px; color: #9ca3af; transition: transform .2s; flex-shrink: 0; }
  details[open] .faq-chevron { transform: rotate(90deg); }
  .faq-a {
    padding: 0 4px 20px 28px;
    font-size: 14px;
    color: #4b5563;
    line-height: 1.75;
  }

  /* ── Footer (same as index.astro) ── */
  .footer { background: #0d1520; color: rgba(255,255,255,0.6); padding: 72px 0 0; }
  .footer .container { max-width: 1160px; }
  .footer-inner {
    display: flex;
    gap: 80px;
    padding-bottom: 56px;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .footer-brand { flex: 1; min-width: 200px; }
  .footer-brand .logo { display: block; margin-bottom: 16px; }
  .footer-brand .logo img { width: 110px; height: auto; display: block; }
  .footer-tagline { font-size: 13px; line-height: 1.7; opacity: 0.45; margin-bottom: 14px; }
  .footer-email { font-size: 12px; color: rgba(255,255,255,0.4); text-decoration: none; transition: color .15s; font-family: monospace; }
  .footer-email:hover { color: rgba(255,255,255,0.8); }
  .footer-links { display: flex; gap: 56px; flex-wrap: wrap; }
  .footer-col { display: flex; flex-direction: column; gap: 12px; }
  .footer-col-title { font-size: 11px; font-weight: 700; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 4px; }
  .footer-col a { font-size: 13.5px; color: rgba(255,255,255,0.55); transition: color 0.15s; }
  .footer-col a:hover { color: #fff; }
  .footer-bottom { padding: 20px 0; }
  .footer-bottom-inner { display: flex; justify-content: space-between; align-items: center; }
  .footer-bottom span { font-size: 12px; opacity: 0.3; }
  .footer-bottom-links { display: flex; gap: 20px; }
  .footer-bottom-links a { font-size: 12px; color: rgba(255,255,255,0.3); transition: color .15s; }
  .footer-bottom-links a:hover { color: rgba(255,255,255,0.6); }

  @media (max-width: 600px) {
    .contact-hero h1 { font-size: 30px; }
    .contact-card { padding: 36px 24px 28px; }
    .footer-inner { flex-direction: column; gap: 32px; }
    .footer-links { flex-wrap: wrap; gap: 32px; }
    .footer-bottom-inner { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>
