  .ss-tab--active .ss-tab-label { color: #fff; }
  .ss-tab-desc {
    font-size: 11px;
    color: var(--text-sub);
    line-height: 1.3;
  }
  .ss-tab--active .ss-tab-desc { color: rgba(255,255,255,0.75); }

  /* Image frame */
  .ss-display {
    border-radius: 20px;
    padding: 20px;
    background: linear-gradient(135deg, #EEF4FF 0%, #F0F4FF 100%);
    border: 1px solid rgba(0,100,224,0.12);
    box-shadow: 0 24px 64px rgba(0,100,224,0.07), 0 4px 12px rgba(0,0,0,0.04);
    display: flex;
    align-items: center;
    gap: 12px;
  }

  /* Prev / Next arrow buttons */
  .ss-arrow {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    background: var(--white);
    color: var(--text);
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .ss-arrow:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: rgba(0,100,224,0.1);
    box-shadow: 0 4px 16px rgba(0,100,224,0.18);
    transform: scale(1.08);
  }
  .ss-arrow:active { transform: scale(0.96); }
  .ss-frame {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    cursor: zoom-in;
    aspect-ratio: 16/9;
    background: #1C2B33;
    flex: 1;
    min-width: 0;
  }
  .ss-frame:hover .ss-expand-hint { opacity: 1; }
  .ss-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
    display: block;
  }
  .ss-img--active { opacity: 1; }
  .ss-expand-hint {
    position: absolute;
    bottom: 14px;
    right: 14px;
    background: rgba(28,43,51,0.72);
    backdrop-filter: blur(6px);
    color: #fff;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 100px;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  /* Dot indicators */
  .ss-dots {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 20px;
  }
  .ss-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background: var(--border);
    cursor: pointer;
    padding: 0;
    transition: all 0.2s ease;
  }
  .ss-dot--active {
    background: var(--primary);
    width: 24px;
    border-radius: 4px;
  }

  /* Lightbox */
  .ss-lightbox {
    position: fixed;
    inset: 0;
    background: rgba(10,15,20,0.88);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    padding: 24px;
  }
  .ss-lightbox--open {
    opacity: 1;
    pointer-events: all;
  }
  .ss-lb-img {
    max-width: 100%;
    max-height: 90vh;
    border-radius: 12px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5);
    transform: scale(0.95);
    transition: transform 0.25s ease;
    display: block;
  }
  .ss-lightbox--open .ss-lb-img { transform: scale(1); }
  .ss-lb-close {
    position: absolute;
    top: 20px;
    right: 24px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.12);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .ss-lb-close:hover { background: rgba(255,255,255,0.22); }

  @media (max-width: 700px) {
    .ss-tabs { flex-direction: column; align-items: stretch; }
    .ss-tab { justify-content: flex-start; }
  }

  /* ── Pricing ── */
  .pricing { padding: 100px 0; background: var(--surface); }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    align-items: start;
  }
  .pricing-free {
    max-width: 520px;
    margin: 0 auto;
  }
  .plan-card--free { text-align: left; }
  .plan-card--free .plan-cta { margin-top: 8px; }
  .plan-card {
    background: var(--white);
    border-radius: 16px;
    padding: 32px;
    border: 1px solid var(--border);
    position: relative;
  }
  .plan-card--featured {
    border-color: var(--primary);
    box-shadow: 0 0 0 4px rgba(0,100,224,0.08);
  }
  .plan-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--primary);
    color: #fff;
    font-size: 11px;
    font-weight: 700;
    padding: 4px 14px;
    border-radius: 100px;
  }
  .plan-header { margin-bottom: 28px; }
  .plan-name { font-size: 14px; font-weight: 700; color: var(--text-sub); text-transform: uppercase; letter-spacing: 0.06em; }
  .plan-price { display: flex; align-items: baseline; gap: 4px; margin: 10px 0 8px; }
  .price { font-size: 36px; font-weight: 900; letter-spacing: -0.02em; }
  .period { font-size: 14px; color: var(--text-sub); }
  .plan-desc { font-size: 13px; color: var(--text-sub); }
  .plan-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
    font-size: 14px;
    line-height: 1.5;
  }
  .plan-features li.disabled { color: var(--text-sub); opacity: 0.5; }
  .plan-features li.plan-feature--highlight {
    color: var(--primary);
    font-weight: 600;
  }
  .plan-cta {
    display: block;
    text-align: center;
    padding: 12px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.15s;
  }
  .plan-cta--primary { background: var(--primary); color: #fff; }
  .plan-cta--primary:hover { background: var(--primary-hover); }
  .plan-cta--outline { border: 1.5px solid var(--border); color: var(--text); }
  .plan-cta--outline:hover { border-color: var(--primary); color: var(--primary); }

  /* ── CTA Banner ── */
  .cta-banner {
    padding: 100px 0;
    background: linear-gradient(135deg, var(--primary) 0%, #0143B5 100%);
    text-align: center;
    color: #fff;
  }
  .cta-banner h2 { font-size: 40px; font-weight: 800; margin-bottom: 16px; letter-spacing: -0.02em; }
  .cta-banner p { font-size: 17px; opacity: 0.85; margin-bottom: 36px; }

  /* ── Footer ── */
  .footer { background: #0f1923; color: rgba(255,255,255,0.7); padding: 64px 0 0; }
  .footer-inner {
    display: flex;
    gap: 80px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-brand { flex: 1; }
  .footer-brand .logo { color: #fff; margin-bottom: 12px; }
  .footer-brand .logo img { width: 110px; height: auto; display: block; }
  .footer-brand p { font-size: 13px; opacity: 0.5; }
  .footer-links { display: flex; gap: 60px; }
  .footer-col { display: flex; flex-direction: column; gap: 12px; }
  .footer-col-title { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.4); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 4px; }
  .footer-col a { font-size: 14px; transition: color 0.15s; }
  .footer-col a:hover { color: #fff; }
  .footer-bottom { padding: 20px 0; }
  .footer-bottom .container { display: flex; justify-content: center; }
  .footer-bottom span { font-size: 12px; opacity: 0.4; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
    .pricing-grid { grid-template-columns: 1fr; max-width: 420px; margin: 0 auto; }
    .screenshots-grid { grid-template-columns: 1fr; }
    .footer-inner { flex-direction: column; gap: 32px; }
    .footer-links { flex-wrap: wrap; gap: 32px; }

    .api-layout { grid-template-columns: 1fr; }
    .api-endpoints { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.06); padding: 16px 0; }
    .api-ep-list { display: flex; flex-wrap: wrap; gap: 4px; padding: 0 12px; }
    .api-ep { border-left: none; border-radius: 8px; padding: 8px 12px; }
    .api-ep--active { border-left: none; }

    .hero { padding: 80px 0 60px; }
    .ai-workflow, .features, .integrations, .screenshots, .pricing { padding: 72px 0; }
    .cta-banner { padding: 72px 0; }
    .cta-banner h2 { font-size: 32px; }
    .section-header { margin-bottom: 48px; }
  }
  @media (max-width: 600px) {
    .features-grid { grid-template-columns: 1fr; }
    .hero { padding: 64px 0 48px; }
    .hero-sub { font-size: 16px; }
    .hero-sub br { display: none; }
    .hero-stats { gap: 16px; }
    .stat-divider { display: none; }
    .ac-modes { flex-direction: column; }
    .cta-banner h2 { font-size: 26px; }
    .cta-banner p { font-size: 15px; }
    .cta-banner > .container > div { flex-direction: column; align-items: center; }
    .footer { padding: 48px 0 0; }
    .section-header h2 { font-size: 26px; }
    .section-header p { font-size: 15px; }
    .ai-workflow, .features, .integrations, .screenshots, .pricing { padding: 56px 0; }
    .plan-card { padding: 24px; }
    .feature-card { padding: 24px; }
  }
</style>

<script>
  // ── API Center: mode switcher ──
  const acModes = document.querySelectorAll<HTMLButtonElement>('.ac-mode');
  const acContents = document.querySelectorAll<HTMLElement>('.ac-content');

  acModes.forEach((btn) => {
    btn.addEventListener('click', () => {
      const mode = btn.dataset.mode!;
      acModes.forEach(b => b.classList.remove('ac-mode--active'));
      acContents.forEach(c => c.classList.add('ac-content--hidden'));
      btn.classList.add('ac-mode--active');
      document.querySelector<HTMLElement>(`[data-content="${mode}"]`)?.classList.remove('ac-content--hidden');
    });
  });

  // ── MCP tool tabs ──
  const mcpContent = document.querySelector<HTMLElement>('[data-content="mcp"]')!;
  const mcpTabs = mcpContent.querySelectorAll<HTMLButtonElement>('.it-tab');
  const mcpPanels = mcpContent.querySelectorAll<HTMLElement>('.it-panel');

  mcpTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const tool = tab.dataset.tool!;
      mcpTabs.forEach(t => t.classList.remove('it-tab--active'));
      mcpPanels.forEach(p => p.classList.add('it-panel--hidden'));
      tab.classList.add('it-tab--active');
      mcpContent.querySelector<HTMLElement>(`[data-panel="${tool}"]`)?.classList.remove('it-panel--hidden');
    });
  });

  // ── API mode: endpoint + language tabs ──
  const apiContent = document.querySelector<HTMLElement>('[data-content="api"]')!;
  const apiEps = apiContent.querySelectorAll<HTMLElement>('.api-ep');
  const apiLangTabs = apiContent.querySelectorAll<HTMLButtonElement>('.it-tab');

  let currentEp = 'schema';
  let currentLang = 'curl';

  function updateApiSnippets() {
    apiContent.querySelectorAll<HTMLElement>('.api-snippet').forEach((s) => {
      const match = s.dataset.ep === currentEp && s.dataset.lang === currentLang;
      s.classList.toggle('api-snippet--hidden', !match);
    });
  }

  apiEps.forEach((ep) => {
    ep.addEventListener('click', () => {
      currentEp = ep.dataset.ep!;
      apiEps.forEach(e => e.classList.remove('api-ep--active'));
      ep.classList.add('api-ep--active');
      updateApiSnippets();
    });
  });

  apiLangTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      currentLang = tab.dataset.lang!;
      apiLangTabs.forEach(t => t.classList.remove('it-tab--active'));
      tab.classList.add('it-tab--active');
      updateApiSnippets();
    });
  });

  // ── Clipboard helper (HTTP 환경 fallback) ──
  function copyText(text: string): Promise<void> {
    if (navigator.clipboard?.writeText) return navigator.clipboard.writeText(text);
    const el = document.createElement('textarea');
    el.value = text;
    el.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
    document.body.appendChild(el);
    el.focus(); el.select();
    try { document.execCommand('copy'); } finally { document.body.removeChild(el); }
    return Promise.resolve();
  }

  // ── Copy buttons (all) ──
  document.querySelectorAll<HTMLButtonElement>('.it-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.copy!;
      const code = document.getElementById(`code-${key}`)?.textContent ?? '';
      copyText(code).then(() => {
        btn.textContent = '✓ 복사됨';
        btn.classList.add('it-copy--copied');
        setTimeout(() => { btn.textContent = '복사'; btn.classList.remove('it-copy--copied'); }, 2000);
      });
    });
  });


  // ── Screenshot tabs ──
  const tabs = document.querySelectorAll<HTMLButtonElement>('.ss-tab');
  const imgs = document.querySelectorAll<HTMLImageElement>('.ss-img');
  const dots = document.querySelectorAll<HTMLButtonElement>('.ss-dot');
  const frame = document.getElementById('ss-frame')!;
  const prevBtn = document.getElementById('ss-prev')!;
  const nextBtn = document.getElementById('ss-next')!;
  const lightbox = document.getElementById('ss-lightbox')!;
  const lbImg = document.getElementById('ss-lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('ss-lb-close')!;

  let current = 0;

  function switchTo(idx: number) {
    tabs[current].classList.remove('ss-tab--active');
    tabs[current].setAttribute('aria-selected', 'false');
    imgs[current].classList.remove('ss-img--active');
    dots[current].classList.remove('ss-dot--active');

    current = idx;

    tabs[current].classList.add('ss-tab--active');
    tabs[current].setAttribute('aria-selected', 'true');
    imgs[current].classList.add('ss-img--active');
    dots[current].classList.add('ss-dot--active');
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => switchTo(Number(tab.dataset.idx)));
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => switchTo(Number(dot.dataset.idx)));
  });

  prevBtn.addEventListener('click', () => switchTo((current + tabs.length - 1) % tabs.length));
  nextBtn.addEventListener('click', () => switchTo((current + 1) % tabs.length));

  // Lightbox
  function openLightbox() {
    const src = (imgs[current] as HTMLImageElement).src;
    const alt = (imgs[current] as HTMLImageElement).alt;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add('ss-lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('ss-lightbox--open');
    document.body.style.overflow = '';
  }

  frame.addEventListener('click', openLightbox);
  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') switchTo((current + 1) % tabs.length);
    if (e.key === 'ArrowLeft') switchTo((current + tabs.length - 1) % tabs.length);
  });
</script>
