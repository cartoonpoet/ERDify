<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.ss-tab');
  const imgs = document.querySelectorAll<HTMLImageElement>('.ss-img');
  const dots = document.querySelectorAll<HTMLButtonElement>('.ss-dot');
  const frame = document.getElementById('ss-frame')!;
  const prevBtn = document.getElementById('ss-prev')!;
  const nextBtn = document.getElementById('ss-next')!;
  const lightbox = document.getElementById('ss-lightbox')!;
  const lbImg = document.getElementById('ss-lb-img') as HTMLImageElement;
  const lbClose = document.getElementById('ss-lb-close')!;

  let current = 0;

  function switchTo(idx: number) {
    tabs[current].classList.remove('ss-tab--active');
    tabs[current].setAttribute('aria-selected', 'false');
    imgs[current].classList.remove('ss-img--active');
    dots[current].classList.remove('ss-dot--active');

    current = idx;

    tabs[current].classList.add('ss-tab--active');
    tabs[current].setAttribute('aria-selected', 'true');
    imgs[current].classList.add('ss-img--active');
    dots[current].classList.add('ss-dot--active');
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => switchTo(Number(tab.dataset.idx)));
  });

  dots.forEach((dot) => {
    dot.addEventListener('click', () => switchTo(Number(dot.dataset.idx)));
  });

  prevBtn.addEventListener('click', () => switchTo((current + tabs.length - 1) % tabs.length));
  nextBtn.addEventListener('click', () => switchTo((current + 1) % tabs.length));

  // Lightbox
  function openLightbox() {
    const src = (imgs[current] as HTMLImageElement).src;
    const alt = (imgs[current] as HTMLImageElement).alt;
    lbImg.src = src;
    lbImg.alt = alt;
    lightbox.classList.add('ss-lightbox--open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.remove('ss-lightbox--open');
    document.body.style.overflow = '';
  }

  frame.addEventListener('click', openLightbox);
  lbClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowRight') switchTo((current + 1) % tabs.length);
    if (e.key === 'ArrowLeft') switchTo((current + tabs.length - 1) % tabs.length);
  });
</script>
