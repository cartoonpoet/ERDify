---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';

// 데모 영상 YouTube ID로 교체하세요
const YOUTUBE_ID = 'YOUR_YOUTUBE_ID';
const APP_URL = 'http://erdify-app.kro.kr';
---

<Layout>
  <SiteHeader />

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="badge">✦ MCP 지원 — Cursor · Claude · Gemini · Codex</div>
      <h1 class="hero-title">
        AI와 함께<br /><span class="highlight">스키마를 관리</span>하세요
      </h1>
      <p class="hero-sub">
        사용하는 AI 도구에서 ERDify MCP를 연결하세요.<br />
        스키마 설계부터 DDL·ORM 생성, 팀 실시간 협업까지 — AI와 함께 일하는 데이터베이스 도구.
      </p>
      <div class="hero-actions">
        <a href={`${APP_URL}/register`} class="btn-primary btn-lg">무료로 시작하기 →</a>
        <a href="#integrations" class="btn-outline btn-lg">연동 가이드 보기</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>Cursor · Claude · Gemini · Codex</strong><span>지원 AI 도구</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>실시간</strong><span>팀 협업</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>MySQL · PostgreSQL · MariaDB</strong><span>지원 데이터베이스</span></div>
      </div>
    </div>
  </section>

  <!-- AI WORKFLOW -->
  <section class="ai-workflow" id="ai-workflow">
    <div class="container">
      <div class="section-header">
        <div class="badge">AI-Native ERD</div>
        <h2>AI와 대화하며 ERD를 함께 완성하세요</h2>
        <p>MCP(Model Context Protocol)로 AI와 연결하세요.<br />스키마 조회부터 수정, 팀 동기화까지 AI와 함께 진행합니다.</p>
      </div>

      <div class="workflow-demo">
        <!-- Chat window -->
        <div class="chat-window">
          <div class="chat-titlebar">
            <span class="chat-dot" style="background:#FF5F57"></span>
            <span class="chat-dot" style="background:#FEBC2E"></span>
            <span class="chat-dot" style="background:#28C840"></span>
            <span class="chat-app-name">Cursor — AI Chat</span>
          </div>
          <div class="chat-body">
            <div class="chat-msg chat-msg--user">
              결제 시스템 추가해줘. orders랑 order_items 테이블 필요해
            </div>
            <div class="chat-msg chat-msg--ai">
              <div class="chat-ai-label">AI (ERDify MCP 연결됨)</div>
              ERDify MCP로 현재 스키마를 확인했습니다.<br />
              <code>orders</code>, <code>order_items</code> 테이블과 <code>users</code>와의 관계를 추가하겠습니다.
              <div class="tool-calls">
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_entity</span>
                  <span class="tool-arg">"orders"</span>
                  <span class="tool-ok">✓</span>
                </div>
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_entity</span>
                  <span class="tool-arg">"order_items"</span>
                  <span class="tool-ok">✓</span>
                </div>
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_relationship</span>
                  <span class="tool-arg">orders → users</span>
                  <span class="tool-ok">✓</span>
                </div>
              </div>
              완료됐습니다. ERD에 반영되었습니다 🎉
            </div>
          </div>
        </div>

        <!-- Benefits -->
        <div class="workflow-benefits">
          <div class="workflow-benefit">
            <span class="wf-num">01</span>
            <div class="wf-text">
              <h4>스키마 컨텍스트 자동 인식</h4>
              <p>연결된 AI가 현재 ERD 전체를 읽어 테이블, 컬럼, 관계, 타입을 정확히 파악합니다.</p>
            </div>
          </div>
          <div class="workflow-benefit">
            <span class="wf-num">02</span>
            <div class="wf-text">
              <h4>자연어로 스키마 수정</h4>
              <p>테이블 추가, 컬럼 변경, FK 설정을 대화하듯 요청하면 ERD에 즉시 반영됩니다.</p>
            </div>
          </div>
          <div class="workflow-benefit">
            <span class="wf-num">03</span>
            <div class="wf-text">
              <h4>팀 전체에 실시간 동기화</h4>
              <p>AI와 함께 수정한 내용이 모든 팀원의 화면에 실시간으로 반영됩니다.</p>
            </div>
          </div>
          <a href={`${APP_URL}/register`} class="btn-primary" style="align-self:flex-start; margin-top:8px;">
            지금 연동해보기 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO VIDEO -->
  <section class="demo" id="demo">
    <div class="container">
      <div class="demo-wrapper">
        <div class="demo-video">
          {YOUTUBE_ID !== 'YOUR_YOUTUBE_ID' ? (
            <iframe
              src={`https://www.youtube.com/embed/${YOUTUBE_ID}?rel=0&modestbranding=1`}
              title="ERDify 데모"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          ) : (
            <div class="video-placeholder">
              <div class="play-btn">▶</div>
              <p>데모 영상</p>
              <span>YouTube ID를 설정하세요</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <div class="badge">핵심 기능</div>
        <h2>ERDify가 다른 이유</h2>
        <p>설계부터 개발까지, 데이터베이스 워크플로우 전체를 커버합니다.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card feature-card--accent">
          <div class="feature-icon">🤖</div>
          <h3>AI 연동 (MCP)</h3>
          <p>AI가 MCP로 ERD를 읽고, 여러분의 지시에 따라 함께 수정합니다. 자연어 한 마디로 테이블·관계·컬럼을 설계하세요.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>실시간 협업</h3>
          <p>팀원과 동시에 ERD를 편집하세요. 커서 위치, 변경 사항이 실시간으로 반영됩니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⇅</div>
          <h3>DDL 가져오기 / 내보내기</h3>
          <p>MySQL, PostgreSQL, MariaDB DDL을 그대로 붙여넣으면 자동으로 ERD가 생성됩니다. COMMENT도 논리명으로 자동 매핑.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⌨</div>
          <h3>ORM 코드 생성</h3>
          <p>ERD에서 TypeORM, Prisma, SQLAlchemy 코드를 바로 내보냅니다. 반복 작업을 줄여드립니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⏱</div>
          <h3>버전 관리</h3>
          <p>변경 이력을 자동으로 기록합니다. 언제든 이전 버전으로 되돌릴 수 있습니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>공유 링크</h3>
          <p>읽기 전용 링크로 팀 외부와 공유하세요. 만료 시간을 설정해 보안을 유지합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- API CENTER -->
  <section class="integrations" id="integrations">
    <div class="container">
      <div class="section-header">
        <div class="badge">API Center</div>
        <h2>ERDify에 연결하는 두 가지 방법</h2>
        <p>AI 도구와 MCP로 연결하거나, REST API로 직접 통합하세요.</p>
      </div>

      <!-- Mode switcher -->
      <div class="ac-modes">
        <button class="ac-mode ac-mode--active" data-mode="mcp">
          <span class="ac-mode-icon">🤖</span>
          <div class="ac-mode-text">
            <span class="ac-mode-title">MCP 연동</span>
            <span class="ac-mode-desc">AI 도구에서 자연어로 스키마 관리</span>
          </div>
        </button>
        <button class="ac-mode" data-mode="api">
          <span class="ac-mode-icon">⚡</span>
          <div class="ac-mode-text">
            <span class="ac-mode-title">REST API</span>
            <span class="ac-mode-desc">직접 통합 · 자동화 · CI/CD</span>
          </div>
        </button>
      </div>

      <!-- ── MCP mode ── -->
      <div class="ac-content" data-content="mcp">
        <div class="it-tabs" role="tablist">
          <button class="it-tab it-tab--active" data-tool="cursor">Cursor</button>
          <button class="it-tab" data-tool="claude">Claude Desktop</button>
          <button class="it-tab" data-tool="gemini">Gemini CLI</button>
          <button class="it-tab" data-tool="codex">Codex CLI</button>
        </div>

        <div class="it-panel" data-panel="cursor">
          <div class="it-meta">
            <div class="it-file-badge">📄 .cursor/mcp.json</div>
            <button class="it-copy" data-copy="cursor">복사</button>
          </div>
          <pre class="it-code" id="code-cursor">{`{
  "mcpServers": {
    "erdify": {
      "command": "npx",
      "args": ["-y", "@erdify/mcp-server@latest"],
      "env": {
        "ERDIFY_API_KEY": "erd_your_api_key_here"
      }
    }
  }
}`}</pre>
        </div>

        <div class="it-panel it-panel--hidden" data-panel="claude">
          <div class="it-meta">
            <div class="it-file-badge">📄 ~/Library/Application Support/Claude/claude_desktop_config.json</div>
            <button class="it-copy" data-copy="claude">복사</button>
          </div>
          <pre class="it-code" id="code-claude">{`{
  "mcpServers": {
    "erdify": {
      "command": "npx",
      "args": ["-y", "@erdify/mcp-server@latest"],
      "env": {
        "ERDIFY_API_KEY": "erd_your_api_key_here"
      }
    }
  }
}`}</pre>
        </div>

        <div class="it-panel it-panel--hidden" data-panel="gemini">
          <div class="it-meta">
            <div class="it-file-badge">📄 ~/.gemini/settings.json</div>
            <button class="it-copy" data-copy="gemini">복사</button>
          </div>
          <pre class="it-code" id="code-gemini">{`{
  "mcpServers": {
    "erdify": {
      "command": "npx",
      "args": ["-y", "@erdify/mcp-server@latest"],
      "env": {
        "ERDIFY_API_KEY": "erd_your_api_key_here"
      }
    }
  }
}`}</pre>
        </div>

        <div class="it-panel it-panel--hidden" data-panel="codex">
          <div class="it-meta">
            <div class="it-file-badge">📄 ~/.codex/config.yaml</div>
            <button class="it-copy" data-copy="codex">복사</button>
          </div>
          <pre class="it-code" id="code-codex">{`mcp_servers:
  erdify:
    command: npx
    args:
      - -y
      - "@erdify/mcp-server@latest"
    env:
      ERDIFY_API_KEY: erd_your_api_key_here`}</pre>
        </div>

        <div class="it-note">
          <span>🔑</span>
          <span>API 키는 ERDify 앱 <strong>설정 → API</strong>에서 발급받을 수 있습니다.</span>
          <a href={`${APP_URL}/settings/api`} class="it-note-link">키 발급하기 →</a>
        </div>
      </div>

      <!-- ── REST API mode ── -->
      <div class="ac-content ac-content--hidden" data-content="api">
        <div class="api-layout">
          <!-- Left: endpoint reference -->
          <div class="api-endpoints">
            <div class="api-ep-title">엔드포인트</div>
            <div class="api-base">https://api.erdify.com/v1</div>
            <ul class="api-ep-list">
              <li class="api-ep api-ep--active" data-ep="schema">
                <span class="api-method api-method--get">GET</span>
                <span class="api-path">/projects/{`{id}`}/schema</span>
              </li>
              <li class="api-ep" data-ep="create">
                <span class="api-method api-method--post">POST</span>
                <span class="api-path">/projects/{`{id}`}/entities</span>
              </li>
              <li class="api-ep" data-ep="ddl">
                <span class="api-method api-method--get">GET</span>
                <span class="api-path">/projects/{`{id}`}/ddl</span>
              </li>
              <li class="api-ep" data-ep="projects">
                <span class="api-method api-method--get">GET</span>
                <span class="api-path">/projects</span>
              </li>
            </ul>
          </div>

          <!-- Right: code examples -->
          <div class="api-code-area">
            <div class="it-tabs" role="tablist">
              <button class="it-tab it-tab--active" data-lang="curl">cURL</button>
              <button class="it-tab" data-lang="js">JavaScript</button>
              <button class="it-tab" data-lang="python">Python</button>
            </div>

            <!-- schema -->
            <div class="api-snippet" data-ep="schema" data-lang="curl">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/schema — 스키마 전체 조회</div>
                <button class="it-copy" data-copy="api-schema-curl">복사</button>
              </div>
              <pre class="it-code" id="code-api-schema-curl">{`curl https://api.erdify.com/v1/projects/proj_abc/schema \\
  -H "Authorization: Bearer erd_your_api_key_here"`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="schema" data-lang="js">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/schema — 스키마 전체 조회</div>
                <button class="it-copy" data-copy="api-schema-js">복사</button>
              </div>
              <pre class="it-code" id="code-api-schema-js">{`import { ERDifyClient } from '@erdify/sdk';

const client = new ERDifyClient({ apiKey: 'erd_your_api_key_here' });

const schema = await client.projects.getSchema('proj_abc');
console.log(schema.entities); // 테이블 배열`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="schema" data-lang="python">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/schema — 스키마 전체 조회</div>
                <button class="it-copy" data-copy="api-schema-python">복사</button>
              </div>
              <pre class="it-code" id="code-api-schema-python">{`from erdify import ERDifyClient

client = ERDifyClient(api_key="erd_your_api_key_here")

schema = client.projects.get_schema("proj_abc")
print(schema.entities)  # 테이블 목록`}</pre>
            </div>

            <!-- create entity -->
            <div class="api-snippet api-snippet--hidden" data-ep="create" data-lang="curl">
              <div class="it-meta">
                <div class="it-file-badge">POST /projects/{`{id}`}/entities — 테이블 추가</div>
                <button class="it-copy" data-copy="api-create-curl">복사</button>
              </div>
              <pre class="it-code" id="code-api-create-curl">{`curl -X POST https://api.erdify.com/v1/projects/proj_abc/entities \\
  -H "Authorization: Bearer erd_your_api_key_here" \\
  -H "Content-Type: application/json" \\
  -d '{
    "name": "orders",
    "columns": [
      { "name": "id",         "type": "INT",           "primaryKey": true },
      { "name": "user_id",    "type": "INT" },
      { "name": "total",      "type": "DECIMAL(10,2)" },
      { "name": "created_at", "type": "TIMESTAMP" }
    ]
  }'`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="create" data-lang="js">
              <div class="it-meta">
                <div class="it-file-badge">POST /projects/{`{id}`}/entities — 테이블 추가</div>
                <button class="it-copy" data-copy="api-create-js">복사</button>
              </div>
              <pre class="it-code" id="code-api-create-js">{`const entity = await client.entities.create('proj_abc', {
  name: 'orders',
  columns: [
    { name: 'id',         type: 'INT',           primaryKey: true },
    { name: 'user_id',    type: 'INT' },
    { name: 'total',      type: 'DECIMAL(10,2)' },
    { name: 'created_at', type: 'TIMESTAMP' },
  ],
});`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="create" data-lang="python">
              <div class="it-meta">
                <div class="it-file-badge">POST /projects/{`{id}`}/entities — 테이블 추가</div>
                <button class="it-copy" data-copy="api-create-python">복사</button>
              </div>
              <pre class="it-code" id="code-api-create-python">{`entity = client.entities.create("proj_abc", {
    "name": "orders",
    "columns": [
        {"name": "id",         "type": "INT",           "primaryKey": True},
        {"name": "user_id",    "type": "INT"},
        {"name": "total",      "type": "DECIMAL(10,2)"},
        {"name": "created_at", "type": "TIMESTAMP"},
    ],
})`}</pre>
            </div>

            <!-- ddl export -->
            <div class="api-snippet api-snippet--hidden" data-ep="ddl" data-lang="curl">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/ddl — DDL 내보내기</div>
                <button class="it-copy" data-copy="api-ddl-curl">복사</button>
              </div>
              <pre class="it-code" id="code-api-ddl-curl">{`curl "https://api.erdify.com/v1/projects/proj_abc/ddl?dialect=postgresql" \\
  -H "Authorization: Bearer erd_your_api_key_here"`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="ddl" data-lang="js">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/ddl — DDL 내보내기</div>
                <button class="it-copy" data-copy="api-ddl-js">복사</button>
              </div>
              <pre class="it-code" id="code-api-ddl-js">{`const ddl = await client.projects.exportDDL('proj_abc', {
  dialect: 'postgresql', // 'mysql' | 'postgresql' | 'mariadb'
});
console.log(ddl); // CREATE TABLE ...`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="ddl" data-lang="python">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects/{`{id}`}/ddl — DDL 내보내기</div>
                <button class="it-copy" data-copy="api-ddl-python">복사</button>
              </div>
              <pre class="it-code" id="code-api-ddl-python">{`ddl = client.projects.export_ddl(
    "proj_abc",
    dialect="postgresql"  # "mysql" | "postgresql" | "mariadb"
)
print(ddl)  # CREATE TABLE ...`}</pre>
            </div>

            <!-- projects list -->
            <div class="api-snippet api-snippet--hidden" data-ep="projects" data-lang="curl">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects — 프로젝트 목록</div>
                <button class="it-copy" data-copy="api-projects-curl">복사</button>
              </div>
              <pre class="it-code" id="code-api-projects-curl">{`curl https://api.erdify.com/v1/projects \\
  -H "Authorization: Bearer erd_your_api_key_here"`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="projects" data-lang="js">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects — 프로젝트 목록</div>
                <button class="it-copy" data-copy="api-projects-js">복사</button>
              </div>
              <pre class="it-code" id="code-api-projects-js">{`const projects = await client.projects.list();
console.log(projects); // [{ id, name, updatedAt }, ...]`}</pre>
            </div>
            <div class="api-snippet api-snippet--hidden" data-ep="projects" data-lang="python">
              <div class="it-meta">
                <div class="it-file-badge">GET /projects — 프로젝트 목록</div>
                <button class="it-copy" data-copy="api-projects-python">복사</button>
              </div>
              <pre class="it-code" id="code-api-projects-python">{`projects = client.projects.list()
print(projects)  # [{"id": ..., "name": ..., "updatedAt": ...}, ...]`}</pre>
            </div>
          </div>
