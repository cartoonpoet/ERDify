  }

  /* ── Screenshots ── */
  .screenshots { padding: 100px 0; }

  /* Tab buttons */
  .ss-tabs {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .ss-tab {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    background: var(--white);
    cursor: pointer;
    transition: all 0.18s ease;
    text-align: left;
  }
  .ss-tab:hover {
    border-color: var(--primary);
    background: rgba(0,100,224,0.1);
  }
  .ss-tab--active {
    border-color: var(--primary);
    background: var(--primary);
    box-shadow: 0 4px 16px rgba(0,100,224,0.25);
  }
  .ss-tab-icon {
    font-size: 20px;
    line-height: 1;
