---
import Layout from '../layouts/Layout.astro';

// 데모 영상 YouTube ID로 교체하세요
const YOUTUBE_ID = 'YOUR_YOUTUBE_ID';
const APP_URL = 'https://app.erdify.com';
---

<Layout>
  <!-- NAV -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="logo">
        <img src="/logo.svg" alt="ERDify" class="logo-image" />
      </a>
      <div class="nav-links">
        <a href="#features">기능</a>
        <a href="#pricing">가격</a>
      </div>
      <div class="nav-cta">
        <a href={`${APP_URL}/login`} class="btn-ghost">로그인</a>
        <a href={`${APP_URL}/register`} class="btn-primary">무료로 시작</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="badge">✦ Claude MCP 공식 연동</div>
      <h1 class="hero-title">
        AI가 팀 스키마를<br /><span class="highlight">직접 관리</span>합니다
      </h1>
      <p class="hero-sub">
        Claude에게 말하면 ERD가 바뀝니다.<br />
        스키마 설계부터 DDL·ORM 생성, 팀 실시간 협업까지 — AI 시대의 데이터베이스 도구.
      </p>
      <div class="hero-actions">
        <a href={`${APP_URL}/register`} class="btn-primary btn-lg">무료로 시작하기 →</a>
        <a href="#ai-workflow" class="btn-outline btn-lg">AI 연동 보기</a>
      </div>
      <div class="hero-stats">
        <div class="stat"><strong>Claude MCP</strong><span>AI 직접 연동</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>실시간</strong><span>팀 협업</span></div>
        <div class="stat-divider"></div>
        <div class="stat"><strong>MySQL · PostgreSQL · MariaDB</strong><span>지원 데이터베이스</span></div>
      </div>
    </div>
  </section>

  <!-- AI WORKFLOW -->
  <section class="ai-workflow" id="ai-workflow">
    <div class="container">
      <div class="section-header">
        <div class="badge">AI-Native ERD</div>
        <h2>Claude에게 말하면 ERD가 바뀝니다</h2>
        <p>MCP(Model Context Protocol)로 연결된 Claude가 팀의 스키마를<br />직접 읽고, 수정하고, 팀 전체에 동기화합니다.</p>
      </div>

      <div class="workflow-demo">
        <!-- Chat window -->
        <div class="chat-window">
          <div class="chat-titlebar">
            <span class="chat-dot" style="background:#FF5F57"></span>
            <span class="chat-dot" style="background:#FEBC2E"></span>
            <span class="chat-dot" style="background:#28C840"></span>
            <span class="chat-app-name">Claude</span>
          </div>
          <div class="chat-body">
            <div class="chat-msg chat-msg--user">
              결제 시스템 추가해줘. orders랑 order_items 테이블 필요해
            </div>
            <div class="chat-msg chat-msg--ai">
              <div class="chat-ai-label">Claude</div>
              ERDify MCP로 현재 스키마를 확인했습니다.<br />
              <code>orders</code>, <code>order_items</code> 테이블과 <code>users</code>와의 관계를 추가하겠습니다.
              <div class="tool-calls">
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_entity</span>
                  <span class="tool-arg">"orders"</span>
                  <span class="tool-ok">✓</span>
                </div>
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_entity</span>
                  <span class="tool-arg">"order_items"</span>
                  <span class="tool-ok">✓</span>
                </div>
                <div class="tool-call">
                  <span class="tool-icon">⚙</span>
                  <span class="tool-name">add_relationship</span>
                  <span class="tool-arg">orders → users</span>
                  <span class="tool-ok">✓</span>
                </div>
              </div>
              완료됐습니다. ERD에 반영되었습니다 🎉
            </div>
          </div>
        </div>

        <!-- Benefits -->
        <div class="workflow-benefits">
          <div class="workflow-benefit">
            <span class="wf-num">01</span>
            <div class="wf-text">
              <h4>스키마 컨텍스트 자동 인식</h4>
              <p>Claude가 현재 ERD 전체를 읽어 테이블, 컬럼, 관계, 타입을 정확히 파악합니다.</p>
            </div>
          </div>
          <div class="workflow-benefit">
            <span class="wf-num">02</span>
            <div class="wf-text">
              <h4>자연어로 스키마 수정</h4>
              <p>테이블 추가, 컬럼 변경, FK 설정을 대화하듯 요청하면 ERD에 즉시 반영됩니다.</p>
            </div>
          </div>
          <div class="workflow-benefit">
            <span class="wf-num">03</span>
            <div class="wf-text">
              <h4>팀 전체에 실시간 동기화</h4>
              <p>AI가 수정한 내용이 모든 팀원의 화면에 실시간으로 반영됩니다.</p>
            </div>
          </div>
          <a href={`${APP_URL}/register`} class="btn-primary" style="align-self:flex-start; margin-top:8px;">
            지금 연동해보기 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO VIDEO -->
  <section class="demo" id="demo">
    <div class="container">
      <div class="demo-wrapper">
        <div class="demo-video">
          {YOUTUBE_ID !== 'YOUR_YOUTUBE_ID' ? (
            <iframe
              src={`https://www.youtube.com/embed/${YOUTUBE_ID}?rel=0&modestbranding=1`}
              title="ERDify 데모"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          ) : (
            <div class="video-placeholder">
              <div class="play-btn">▶</div>
              <p>데모 영상</p>
              <span>YouTube ID를 설정하세요</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-header">
        <div class="badge">핵심 기능</div>
        <h2>ERDify가 다른 이유</h2>
        <p>설계부터 개발까지, 데이터베이스 워크플로우 전체를 커버합니다.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card feature-card--accent">
          <div class="feature-icon">🤖</div>
          <h3>AI 연동 (MCP)</h3>
          <p>Claude가 MCP로 ERD를 직접 읽고 수정합니다. 자연어 한 마디로 테이블·관계·컬럼을 추가하세요.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>실시간 협업</h3>
          <p>팀원과 동시에 ERD를 편집하세요. 커서 위치, 변경 사항이 실시간으로 반영됩니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⇅</div>
          <h3>DDL 가져오기 / 내보내기</h3>
          <p>MySQL, PostgreSQL, MariaDB DDL을 그대로 붙여넣으면 자동으로 ERD가 생성됩니다. COMMENT도 논리명으로 자동 매핑.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⌨</div>
          <h3>ORM 코드 생성</h3>
          <p>ERD에서 TypeORM, Prisma, SQLAlchemy 코드를 바로 내보냅니다. 반복 작업을 줄여드립니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⏱</div>
          <h3>버전 관리</h3>
          <p>변경 이력을 자동으로 기록합니다. 언제든 이전 버전으로 되돌릴 수 있습니다.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔗</div>
          <h3>공유 링크</h3>
          <p>읽기 전용 링크로 팀 외부와 공유하세요. 만료 시간을 설정해 보안을 유지합니다.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="screenshots">
    <div class="container">
      <div class="section-header">
        <div class="badge">스크린샷</div>
        <h2>직관적인 에디터</h2>
        <p>복잡한 ERD도 쉽고 빠르게 편집하세요.</p>
      </div>

      <!-- Tab buttons -->
      <div class="ss-tabs" role="tablist">
        <button class="ss-tab ss-tab--active" role="tab" aria-selected="true" data-idx="0">
          <span class="ss-tab-icon">⊞</span>
          <span class="ss-tab-text">
            <span class="ss-tab-label">에디터</span>
            <span class="ss-tab-desc">테이블·컬럼·관계선 편집</span>
          </span>
        </button>
        <button class="ss-tab" role="tab" aria-selected="false" data-idx="1">
          <span class="ss-tab-icon">⚡</span>
          <span class="ss-tab-text">
            <span class="ss-tab-label">실시간 협업</span>
            <span class="ss-tab-desc">팀원 커서 실시간 반영</span>
          </span>
        </button>
        <button class="ss-tab" role="tab" aria-selected="false" data-idx="2">
          <span class="ss-tab-icon">⇅</span>
          <span class="ss-tab-text">
            <span class="ss-tab-label">DDL 가져오기</span>
            <span class="ss-tab-desc">SQL → ERD 자동 변환</span>
          </span>
        </button>
      </div>

      <!-- Large image display -->
      <div class="ss-display">
        <button class="ss-arrow ss-arrow--prev" id="ss-prev" aria-label="이전">&#8592;</button>
        <div class="ss-frame" id="ss-frame" title="클릭하여 크게 보기">
          <img class="ss-img ss-img--active" src="/screenshots/editor.svg"
            alt="ERDify 에디터 — 테이블, 컬럼, 관계선을 직관적으로 편집" data-idx="0" />
          <img class="ss-img" src="/screenshots/collaboration.svg"
            alt="실시간 협업 — 팀원 커서와 편집 내용이 실시간으로 반영" data-idx="1" />
          <img class="ss-img" src="/screenshots/import-ddl.svg"
            alt="DDL 가져오기 — CREATE TABLE SQL을 붙여넣으면 ERD 자동 생성" data-idx="2" />
          <div class="ss-expand-hint">🔍 클릭하여 크게 보기</div>
        </div>
        <button class="ss-arrow ss-arrow--next" id="ss-next" aria-label="다음">&#8594;</button>
      </div>

      <!-- Dot indicators -->
      <div class="ss-dots">
        <button class="ss-dot ss-dot--active" data-idx="0" aria-label="에디터"></button>
        <button class="ss-dot" data-idx="1" aria-label="실시간 협업"></button>
        <button class="ss-dot" data-idx="2" aria-label="DDL 가져오기"></button>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="ss-lightbox" id="ss-lightbox" role="dialog" aria-modal="true" aria-label="이미지 크게 보기">
    <button class="ss-lb-close" id="ss-lb-close" aria-label="닫기">×</button>
    <img class="ss-lb-img" id="ss-lb-img" src="" alt="" />
  </div>

  <!-- PRICING -->
  <section class="pricing" id="pricing">
    <div class="container">
      <div class="section-header">
        <div class="badge">가격 정책</div>
        <h2>팀 규모에 맞게</h2>
        <p>혼자 시작해서 팀으로 성장하세요. 언제든 플랜을 변경할 수 있습니다.</p>
      </div>
      <div class="pricing-grid">
        <!-- FREE -->
        <div class="plan-card">
          <div class="plan-header">
            <span class="plan-name">Free</span>
            <div class="plan-price"><span class="price">₩0</span><span class="period">/월</span></div>
            <p class="plan-desc">개인 프로젝트에 최적</p>
          </div>
          <ul class="plan-features">
            <li>✓ 다이어그램 10개</li>
            <li>✓ DDL 가져오기 / 내보내기</li>
            <li>✓ ORM 코드 생성</li>
            <li>✓ 공유 링크 (최대 1시간)</li>
            <li class="disabled">✗ 실시간 협업</li>
            <li class="disabled">✗ 버전 히스토리</li>
          </ul>
          <a href={`${APP_URL}/register`} class="plan-cta plan-cta--outline">무료로 시작</a>
        </div>

        <!-- PRO -->
        <div class="plan-card plan-card--featured">
          <div class="plan-badge">인기</div>
          <div class="plan-header">
            <span class="plan-name">Pro</span>
            <div class="plan-price"><span class="price">₩9,900</span><span class="period">/월</span></div>
            <p class="plan-desc">개인 전문가용</p>
          </div>
          <ul class="plan-features">
            <li>✓ 무제한 다이어그램</li>
            <li>✓ DDL 가져오기 / 내보내기</li>
            <li>✓ ORM 코드 생성</li>
            <li>✓ 공유 링크 (최대 30일)</li>
            <li>✓ 버전 히스토리 30개</li>
            <li class="disabled">✗ 실시간 협업</li>
          </ul>
          <a href={`${APP_URL}/register?plan=pro`} class="plan-cta plan-cta--primary">시작하기</a>
        </div>

        <!-- TEAM -->
        <div class="plan-card">
          <div class="plan-header">
            <span class="plan-name">Team</span>
            <div class="plan-price"><span class="price">₩29,000</span><span class="period">/월</span></div>
            <p class="plan-desc">팀 협업에 최적</p>
          </div>
          <ul class="plan-features">
            <li>✓ 무제한 다이어그램</li>
            <li>✓ DDL 가져오기 / 내보내기</li>
            <li>✓ ORM 코드 생성</li>
            <li>✓ 공유 링크 (최대 30일)</li>
            <li>✓ <strong>실시간 협업</strong></li>
            <li>✓ 버전 히스토리 무제한</li>
            <li>✓ 멤버 역할 관리 (RBAC)</li>
            <li>✓ AI(MCP) 연동</li>
          </ul>
          <a href={`${APP_URL}/register?plan=team`} class="plan-cta plan-cta--outline">팀 시작하기</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner">
    <div class="container">
      <h2>지금 바로 시작하세요</h2>
      <p>신용카드 없이 무료로 시작할 수 있습니다.</p>
      <a href={`${APP_URL}/register`} class="btn-primary btn-lg btn-white">무료로 시작하기 →</a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo">
          <img src="/logo.svg" alt="ERDify" class="logo-image" />
        </a>
        <p>실시간 협업 ERD 도구</p>
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">제품</span>
          <a href="#features">기능</a>
          <a href="#pricing">가격</a>
          <a href={APP_URL}>앱 열기</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">지원</span>
          <a href="mailto:support@erdify.com">문의하기</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container">
        <span>© 2025 ERDify. All rights reserved.</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* ── Layout ── */
  .container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Nav ── */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 60px;
  }
  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .logo-image {
    display: block;
    width: 138px;
    height: 36px;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    flex: 1;
  }
  .nav-links a {
    font-size: 14px;
    color: var(--text-sub);
    font-weight: 500;
    transition: color 0.15s;
  }
  .nav-links a:hover { color: var(--text); }
  .nav-cta { display: flex; gap: 10px; align-items: center; }

  /* ── Buttons ── */
  .btn-primary {
    background: var(--primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 14px;
    font-weight: 600;
    transition: background 0.15s;
  }
  .btn-primary:hover { background: var(--primary-hover); }
  .btn-ghost {
    color: var(--text-sub);
    font-size: 14px;
    font-weight: 500;
    padding: 9px 14px;
    border-radius: 8px;
    transition: background 0.15s;
  }
  .btn-ghost:hover { background: var(--surface); }
  .btn-outline {
    border: 1.5px solid var(--border);
    color: var(--text);
    border-radius: 8px;
    padding: 9px 18px;
    font-size: 14px;
    font-weight: 600;
    transition: border-color 0.15s;
  }
  .btn-outline:hover { border-color: var(--primary); color: var(--primary); }
  .btn-lg { padding: 14px 28px; font-size: 16px; border-radius: 10px; }
  .btn-white { background: #fff; color: var(--primary); }
  .btn-white:hover { background: #f0f6ff; }

  /* ── Badge ── */
  .badge {
    display: inline-block;
    background: #EEF4FF;
    color: var(--primary);
    font-size: 12px;
    font-weight: 700;
    padding: 5px 12px;
    border-radius: 100px;
    letter-spacing: 0.02em;
    margin-bottom: 20px;
  }

  /* ── Hero ── */
  .hero {
    padding: 100px 0 80px;
    text-align: center;
  }
  .hero-title {
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }
  .highlight {
    color: var(--primary);
    position: relative;
  }
  .hero-sub {
    font-size: 18px;
    color: var(--text-sub);
    line-height: 1.7;
    margin-bottom: 40px;
  }
  .hero-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 60px;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat strong { font-size: 15px; font-weight: 700; }
  .stat span { font-size: 12px; color: var(--text-sub); }
  .stat-divider { width: 1px; height: 32px; background: var(--border); }

  /* ── Demo Video ── */
  .demo { padding: 0 0 100px; }
  .demo-wrapper {
    background: linear-gradient(135deg, #EEF4FF 0%, #f8f9fb 100%);
    border-radius: 20px;
    padding: 24px;
    border: 1px solid var(--border);
    box-shadow: 0 24px 64px rgba(0,100,224,0.08), 0 4px 12px rgba(0,0,0,0.04);
  }
  .demo-video {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16/9;
    background: #1C2B33;
  }
  .demo-video iframe { width: 100%; height: 100%; }
  .video-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    color: rgba(255,255,255,0.6);
  }
  .play-btn {
    width: 72px;
