{
  "name": "@erdify/api",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "node --require @swc-node/register src/main.ts",
    "prebuild": "pnpm --filter @erdify/db build && pnpm --filter @erdify/contracts build",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "pretypecheck": "pnpm --filter @erdify/db build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @erdify/db build && pnpm --filter @erdify/domain build",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.1",
    "@automerge/automerge": "^3.2.6",
    "@erdify/contracts": "workspace:*",
    "@erdify/db": "workspace:*",
    "@erdify/domain": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.19",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "nodemailer": "^8.0.7",
    "openai": "^4.98.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-kakao": "^1.0.1",
    "passport-naver-v2": "^2.0.8",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.22",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@erdify/config-eslint": "workspace:*",
    "@erdify/config-typescript": "workspace:*",
    "@nestjs/testing": "^11.1.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-kakao": "^1.0.3",
    "@types/pg": "^8.11.13",
    "@vitest/coverage-v8": "^3.2.7",
    "tsx": "^4.19.4",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.1.2"
  }
}
