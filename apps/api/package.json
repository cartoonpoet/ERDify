{
  "name": "@erdify/api",
  "private": true,
  "version": "0.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "node --require @swc-node/register src/main.ts",
    "prebuild": "pnpm --filter @erdify/db build",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "pretypecheck": "pnpm --filter @erdify/db build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "pnpm --filter @erdify/db build",
    "test": "vitest run"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@erdify/db": "workspace:*",
    "@erdify/domain": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/platform-socket.io": "^11.1.19",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.19",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.15.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.22",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@erdify/config-eslint": "workspace:*",
    "@erdify/config-typescript": "workspace:*",
    "@nestjs/testing": "^11.1.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.32",
    "@types/bcryptjs": "^3.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.13",
    "tsx": "^4.19.4",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.1.2"
  }
}
